#!/usr/bin/env bash

set -euo pipefail

IFS=$'\n\t'

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" &>/dev/null && pwd)
readonly SCRIPT_DIR

if [[ "${DEBUG-}" =~ ^1|yes|true$ ]]; then
    set -x
fi

readonly CURRENT_HOST=$(hostname)
readonly LOCK_FILE="/tmp/$USER-notes-git-sync.lock"

cd ~/Documents/notes/vault || exit

sync_repo() {
    (
        flock -w 5 9 || exit 0

        if [[ -n "$(git status --porcelain)" ]]; then
            git add .
            if ! git diff --staged --quiet; then
                git commit -m "[${CURRENT_HOST}] $(date +'%Y-%m-%d %H:%M:%S')"
            fi
        fi

        git pull --rebase || true
        git push || true

    ) 9>"${LOCK_FILE}"
}

background_sync() {
    while true; do
        sleep 600
        sync_repo
    done
}

(
    flock -w 10 9 || exit 1
    git pull --rebase --autostash || true
) 9>"${LOCK_FILE}"

set -m
background_sync </dev/null &>/dev/null &
SYNC_PID=$!
set +m

cleanup_bg() { kill -TERM -"${SYNC_PID:-}" 2>/dev/null || true; }
trap cleanup_bg EXIT

nvim index.md

cleanup_bg
sync_repo
