#!/usr/bin/env bash
set -euo pipefail

# Enable tracing when DEBUG=1/yes/true
[[ "${DEBUG-}" =~ ^(1|yes|true)$ ]] && set -x

cd ~/Documents/notes/vault
CURRENT_HOST=$(hostname)
readonly CURRENT_HOST

sync_repo() {
    git pull --rebase
    if [[ -n "$(git status --porcelain)" ]]; then
        git add .
        git commit -m "[${CURRENT_HOST}] Auto-commit: $(date +'%Y-%m-%d %H:%M:%S')"
        git push
    fi
}

background_sync() {
    while true; do
        sleep 600
        sync_repo
    done
}

git pull --rebase

# Job control (`set -m`) makes bash give this background job its own
# process group, so "kill -TERM -$SYNC_PID" (note the leading "-") can
# later kill the loop *and* any git command it's mid-running, without
# touching this script's own process group.
set -m
background_sync </dev/null &>/dev/null &
SYNC_PID=$!
set +m

cleanup_bg() { kill -TERM -"${SYNC_PID:-}" 2>/dev/null || true; }
trap cleanup_bg EXIT

nvim index.md

# Stop the loop before the final sync so they don't race on git's lock
cleanup_bg
sync_repo
