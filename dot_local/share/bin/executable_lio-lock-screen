#!/usr/bin/env bash

playerctl --all-players pause

# Lock the screen
pidof hyprlock || hyprlock &

if [[ "$XDG_CURRENT_DESKTOP" == "niri" ]]; then
    sleep 1
    niri msg action power-off-monitors
fi

