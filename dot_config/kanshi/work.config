profile laptop-only {
    output eDP-1 {
        mode "2880x1800@120.000" 
        position 0,0
        scale 1.5
        adaptive_sync on
    }
}

profile fallback {
    output eDP-1 {
        mode "2880x1800@120.000" 
        position 0,0
        scale 1.5
        adaptive_sync on
    }

    output "*" { }
}
